# Celo Mainnet RPC. Forno is the public default.
CELO_RPC_URL=https://forno.celo.org

# Hot wallet private key for the meRacle agent.
# Generate fresh, NEVER reuse a personal wallet. Fund with a small
# amount of cUSD for gas (a few cents covers months of submissions).
# Required for every register / submit script.
AGENT_PRIVATE_KEY=

# Mercato PriceOracle proxy on Celo Mainnet, where submissions land.
MERCATO_ADDRESS=0x18DD82604a9439b3Cdb7E1078c355E460ED217Ed

# ERC-8004 registries on Celo Mainnet.
IDENTITY_REGISTRY=0x8004A169FB4a3325136EB29fA0ceB6D2e539a432
REPUTATION_REGISTRY=0x8004BAa17C55a88189AE136b182e5fdA19dE9b63

# Self Agent ID Registry on Celo Mainnet, read-only for now.
# Actual registration happens through the Self web app (app.ai.self.xyz).
SELF_AGENT_REGISTRY=0xaC3DF9ABf80d0F5c020C06B04Cced27763355944

# cUSD on Celo Mainnet. Native fee currency: used directly as the
# address in `feeCurrency`, no adapter required (cUSD is 18-decimal,
# adapters are only for 6-decimal tokens like USDC/USDT).
CUSD_ADDRESS=0x765DE816845861e75A25fCA122bb6898B8B1282a

# Agent metadata URI for the ERC-8004 Identity Registry tokenURI.
# Default points at the agent.json checked into this repo's main
# branch (served via GitHub raw). Override only if hosting metadata
# elsewhere (IPFS, custom domain, etc.).
AGENT_METADATA_URI=https://raw.githubusercontent.com/BRN-SLP/meracle/main/agent.json

# Browser Use Cloud API key. Used only by the UK scraper, which spins
# up a remote chromium session behind a UK residential proxy to bypass
# Akamai bot protection on Sainsbury's / Tesco / etc. Get one (no card)
# at https://cloud.browser-use.com/settings?tab=api-keys&new=1.
# Leave blank to disable the UK scraper.
BROWSER_USE_API_KEY=

# Ed25519 keypair used ONLY by scripts/register-self.ts to register
# the agent on Self Agent ID (app.ai.self.xyz). Generate fresh per
# agent and store the private key out of band, losing it means
# losing the Self Agent ID. Generation snippet:
#   node -e "const{generateKeyPairSync}=require('crypto');\
#     const{publicKey,privateKey}=generateKeyPairSync('ed25519');\
#     console.log('pub:',publicKey.export({format:'der',type:'spki'}).subarray(-32).toString('hex'));\
#     console.log('priv:',privateKey.export({format:'der',type:'pkcs8'}).subarray(-32).toString('hex'))"
SELF_AGENT_ED25519_PUBLIC=
SELF_AGENT_ED25519_PRIVATE=

# Personal EVM wallet that will own the Self Agent ID NFT. Passport
# ZK proof from the Self mobile app is attached to this address during
# registration, so it becomes a permanent "verified human" record on
# the Self Agent ID Registry. Distinct from AGENT_PRIVATE_KEY (which
# is the agent hot wallet that submits prices). Use a personal wallet
# on Celo Mainnet that you control. Required only by register:self.
SELF_HUMAN_ADDRESS=

# REWE Germany delivery market identifier. Without it the rewe-de
# scraper reports 16 clean misses with reason "REWE market not
# configured". Capture procedure (one-off, six-month rotation):
#   1. Open shop.rewe.de in a Browser Use Cloud session with DE proxy
#   2. Dismiss the Usercentrics consent overlay
#   3. Open "Standort wählen", enter 10115 Berlin Mitte
#   4. Click the suggested market, toggle Lieferservice mode
#   5. Read the `wwIdent` cookie set on shop.rewe.de
#   6. Paste here. Both keys hold the same numeric value in practice.
# See docs/deferred-retailers.md for full discovery procedure.
REWE_WW_IDENT=
REWE_MARKET_CODE=
