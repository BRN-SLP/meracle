{
  "name": "meracle",
  "version": "0.1.0",
  "description": "Reference Price Oracle for Mercato. ERC-8004 registered agent that scrapes retailer prices and submits them on-chain.",
  "license": "MIT",
  "author": "BRN-SLP <v.khylynskyi@gmail.com>",
  "type": "module",
  "engines": {
    "node": ">=20"
