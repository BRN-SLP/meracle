    "test": "node --import tsx --test src/*.test.ts src/scrapers/*.test.ts",
    "build": "tsc",
    "register:identity": "tsx scripts/register-identity.ts",
    "register:self": "tsx scripts/register-self.ts",
    "scrape:novus": "tsx scripts/scrape-novus-ua.ts",
    "scrape:auchan-ua": "tsx scripts/scrape-auchan-ua.ts",
    "scrape:tavriav-ua": "tsx scripts/scrape-tavriav-ua.ts",
    "scrape:mercadona": "tsx scripts/scrape-mercadona-es.ts",
    "scrape:sainsburys": "tsx scripts/scrape-sainsburys-uk.ts",
    "scrape:conad": "tsx scripts/scrape-conad-it.ts",
    "scrape:carrefour": "tsx scripts/scrape-carrefour-fr.ts",
    "browseruse:usage": "tsx scripts/browseruse-usage.ts",
    "submit:batch": "tsx scripts/submit-batch.ts",
    "feedback:read": "tsx scripts/read-feedback.ts",
    "scrape": "tsx src/scrape.ts",
    "submit": "tsx src/submit.ts"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "playwright-core": "^1.60.0",
    "viem": "^2.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
